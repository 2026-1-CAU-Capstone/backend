# =============================================================
# Jazzify Backend – 운영 환경 (prod) 환경변수 예시
# 서버에 배포할 때 이 파일을 기반으로 .env 를 생성하세요.
# docker-compose-server.yml 이 이 .env 파일을 읽습니다 (env_file: .env).
# 절대 Git에 커밋하지 마세요.
# =============================================================


# =============================================================
# [JVM] 메모리 설정
# Dockerfile의 JAVA_OPTS 기본값을 여기서 오버라이드할 수 있습니다.
# -Xms          : JVM 시작 시 즉시 확보할 힙 크기
# -Xmx          : 힙이 늘어날 수 있는 최대 크기
# -MaxRAMPercentage: 컨테이너 메모리의 몇 %까지 힙으로 쓸지 (UseContainerSupport 필요)
# 서버 RAM이 1 GB라면 -Xmx512m / 2 GB라면 -Xmx1g 정도가 일반적입니다.
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:+UseG1GC -XX:+OptimizeStringConcat -Djava.security.egd=file:/dev/./urandom
# =============================================================


# =============================================================
# [Docker] MySQL 컨테이너 (db 서비스)
# docker-compose-server.yml 의 db 서비스가 이 값으로 컨테이너를 초기화합니다.
# DB_ROOT 는 MySQL root 계정 비밀번호로, healthcheck 에도 사용됩니다.
# =============================================================
DB_NAME=jazzify
DB_USERNAME=jazzify
DB_PASSWORD=strong_db_password_here
DB_ROOT=strong_root_password_here


# =============================================================
# [Spring] Main Database (MySQL) 접속 정보
# application-prod.yml 의 spring.datasource 에 주입됩니다.
# docker-compose-server.yml 사용 시 DB_HOST 는 서비스명 'db' 로 고정합니다.
# =============================================================
DB_DRIVER=mysql
DB_HOST=db
DB_PORT=3306


# =============================================================
# [Docker] Redis 컨테이너 (redis 서비스)
# docker-compose-server.yml 의 redis 서비스가 이 비밀번호로 기동됩니다.
# =============================================================
REDIS_PASSWORD=strong_redis_password_here


# =============================================================
# [Spring] Redis 접속 정보
# docker-compose-server.yml 사용 시 REDIS_HOST 는 서비스명 'redis' 로 고정합니다.
# =============================================================
REDIS_HOST=redis
REDIS_PORT=6379


# =============================================================
# [Spring] JWT
# JWT_SECRET 은 운영 환경에서 반드시 64자 이상의 랜덤 문자열로 교체하세요.
# 생성 예시: openssl rand -base64 64
# =============================================================
JWT_SECRET=replace-with-random-64-chars-openssl-rand-base64-64-output
# Access Token 만료 시간 (밀리초) — 1,800,000 = 30분
JWT_ACCESS_EXPIRATION=1800000
# Refresh Token 만료 시간 (밀리초) — 604,800,000 = 7일
JWT_REFRESH_EXPIRATION=604800000


# =============================================================
# [Spring] CORS
# 실제 서비스 도메인으로 교체하세요.
# =============================================================
CORS_ALLOWED_ORIGINS=https://jazzify.example.com


# =============================================================
# [Spring] AI (Anthropic Claude)
# 발급: https://console.anthropic.com/settings/keys
# =============================================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx


# =============================================================
# [Spring] OMR Server
# 악보 광학 인식 서버의 실제 운영 URL
# =============================================================
OMR_SERVER_URL=http://omr-server:8001


# =============================================================
# [Spring] RAG – PostgreSQL (pgvector)
# RAG 전용 PostgreSQL 인스턴스 접속 정보.
# docker-compose-server.yml 에 pgvector 서비스를 추가한 경우
# RAG_DB_HOST 를 해당 서비스명으로 맞추세요.
# RAG_DB_URL 의 호스트는 서비스명 'pgvector' 로 고정합니다.
# =============================================================
RAG_DB_NAME=rag_db
RAG_DB_URL=jdbc:postgresql://pgvector:5432/${RAG_DB_NAME}
RAG_DB_USERNAME=rag_user
RAG_DB_PASSWORD=strong_rag_db_password_here


# =============================================================
# [Spring] RAG – Embedding Server
# 텍스트 → 벡터 변환 서버 주소
# =============================================================
RAG_EMBEDDING_SERVER_URL=http://embedding-server:8002
# 외부망 노출 시 인증 키 설정 (내부망이면 비워도 됨)
RAG_EMBEDDING_API_KEY=


# =============================================================
# [Spring] RAG – Vector Store (pgvector 테이블 설정)
# =============================================================
# 벡터를 저장할 PostgreSQL 스키마 이름 (보통 public)
RAG_VECTOR_SCHEMA=public
# 벡터를 저장할 테이블 이름
RAG_VECTOR_TABLE=rag_chunk_store
# 임베딩 벡터 차원 수. 사용하는 임베딩 모델과 반드시 일치해야 합니다.
# multilingual-e5-base → 768 / all-MiniLM-L6-v2 → 384
RAG_VECTOR_DIMENSIONS=768

