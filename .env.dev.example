# =============================================================
# Jazzify Backend – 개발 환경 (dev) 환경변수 예시
# 복사 후 .env 로 이름을 바꾸고 실제 값을 채우세요.
# IntelliJ Run Configuration 또는 로컬 docker-compose에서 사용합니다.
# 절대 Git에 커밋하지 마세요.
# =============================================================


# ── Server ────────────────────────────────────────────────────
# 앱이 바인딩할 HTTP 포트 (기본 8080)
SERVER_PORT=8080


# ── Main Database (MySQL) ─────────────────────────────────────
# JDBC URL은 application-dev.yml에서 아래 변수들을 조합해 생성합니다:
#   jdbc:{DB_DRIVER}://{DB_HOST}:{DB_PORT}/{DB_NAME}
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jazzify
DB_USERNAME=jazzify
DB_PASSWORD=1234


# ── Redis ─────────────────────────────────────────────────────
# 토큰 블랙리스트 · 세션 캐시에 사용하는 Redis 접속 정보
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# ── JWT ───────────────────────────────────────────────────────
# 서명 키: 개발 환경에서는 아무 문자열이나 사용 가능 (32자 이상 권장)
JWT_SECRET=dev-secret-key-please-change-in-production-at-least-32-characters-long
# Access Token 만료 시간 (밀리초) — 3,600,000 = 1시간
JWT_ACCESS_EXPIRATION=3600000
# Refresh Token 만료 시간 (밀리초) — 604,800,000 = 7일
JWT_REFRESH_EXPIRATION=604800000


# ── CORS ──────────────────────────────────────────────────────
# 허용할 프론트엔드 Origin (쉼표로 구분)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# ── AI (Anthropic Claude) ─────────────────────────────────────
# Claude API 호출에 사용하는 시크릿 키
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx


# ── OMR Server ────────────────────────────────────────────────
# 악보 광학 인식(OMR) 처리를 담당하는 외부 서버 URL
OMR_SERVER_URL=http://localhost:8001


# ── RAG – PostgreSQL (pgvector) ───────────────────────────────
# RAG 기능 전용 PostgreSQL 데이터베이스 접속 정보
# MySQL과 완전히 별개의 DB 인스턴스입니다.
#
# 로컬에서 pgvector 컨테이너를 띄우는 방법:
#   docker run -d --name pgvector \
#     -e POSTGRES_DB=rag_db \
#     -e POSTGRES_USER=rag_user \
#     -e POSTGRES_PASSWORD=rag_pass \
#     -p 5432:5432 pgvector/pgvector:pg16
RAG_DB_URL=jdbc:postgresql://localhost:5432/rag_db
RAG_DB_USERNAME=rag_user
RAG_DB_PASSWORD=rag_pass


# ── RAG – Embedding Server ────────────────────────────────────
# 텍스트를 벡터로 변환해주는 임베딩 전용 서버 주소
# (rag/ 디렉터리의 Python 서버를 로컬에서 실행하는 경우)
RAG_EMBEDDING_SERVER_URL=http://localhost:8002
# 임베딩 서버 인증 키. 내부망이라면 비워도 됩니다.
RAG_EMBEDDING_API_KEY=


# ── RAG – Vector Store (pgvector 테이블 설정) ─────────────────
# 벡터를 저장할 PostgreSQL 스키마 이름 (보통 public)
RAG_VECTOR_SCHEMA=public
# 벡터를 저장할 테이블 이름
RAG_VECTOR_TABLE=rag_chunk_store
# 임베딩 벡터 차원 수. 사용하는 임베딩 모델과 반드시 일치해야 합니다.
# multilingual-e5-base → 768 / all-MiniLM-L6-v2 → 384
RAG_VECTOR_DIMENSIONS=768

